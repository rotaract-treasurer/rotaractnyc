# =====================================================================
# Rotaract NYC — Environment Variables
# =====================================================================
# Copy this file to .env.local and fill in all REQUIRED values.
# Variables marked [OPTIONAL] have sensible defaults or degrade gracefully.
#
# Prefix rules:
#   NEXT_PUBLIC_*  → Exposed to the browser (client + server)
#   All others     → Server-only (API routes, SSR)
# =====================================================================


# ─── FIREBASE CLIENT SDK (client-exposed) ───────────────────────────
# Get these from: Firebase Console → Project Settings → Your Apps → Web App
# REQUIRED — the app will not initialise without these
NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key-here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=rotaractnyc-ac453.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=rotaractnyc-ac453
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=rotaractnyc-ac453.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id-here
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id-here


# ─── FIREBASE ADMIN SDK (server-only) ───────────────────────────────
# Choose ONE of the three methods below.
#
# Method 1 (recommended): Full service-account JSON as a single env var
# Download from: Firebase Console → Project Settings → Service Accounts → Generate New Private Key
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"rotaractnyc-ac453",...}
# — OR — Method 2: Same JSON, base64-encoded (some hosts require this)
# FIREBASE_SERVICE_ACCOUNT_BASE64=base64-encoded-service-account-json
# — OR — Method 3: Individual fields
# FIREBASE_PROJECT_ID=rotaractnyc-ac453
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@rotaractnyc-ac453.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"


# ─── ADMIN ALLOWLIST (server-only) ──────────────────────────────────
# Comma-separated emails that are auto-approved as admin on first sign-in
# [OPTIONAL] — if unset, no auto-admin promotion occurs
ADMIN_ALLOWLIST=admin@rotaractnyc.org


# ─── STRIPE (server-only) ───────────────────────────────────────────
# Get keys from: https://dashboard.stripe.com/apikeys
# REQUIRED for donations, dues payments, and event tickets
STRIPE_SECRET_KEY=sk_test_your-secret-key-here

# Webhook signing secret — https://dashboard.stripe.com/webhooks
# REQUIRED for processing payment confirmations
# Local testing: stripe listen --forward-to localhost:3000/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret-here


# ─── RESEND / EMAIL (server-only) ───────────────────────────────────
# Get an API key from: https://resend.com/api-keys
# REQUIRED for contact form, membership interest, and dues reminder emails
RESEND_API_KEY=re_your-api-key-here

# Sender address — must use a verified domain in Resend
# [OPTIONAL] — defaults to "Rotaract NYC <noreply@rotaractnyc.org>"
RESEND_FROM_EMAIL=Rotaract NYC <noreply@rotaractnyc.org>

# Where contact/membership-interest form submissions are sent
# [OPTIONAL] — defaults to rotaractnewyorkcity@gmail.com
RESEND_TO_EMAIL=rotaractnewyorkcity@gmail.com


# ─── UPSTASH REDIS (server-only) ────────────────────────────────────
# Used for distributed rate limiting in serverless (Vercel) environments.
# Get credentials from: https://console.upstash.com
# [OPTIONAL] — falls back to in-memory rate limiting if unset (fine for dev,
# but STRONGLY RECOMMENDED for production to prevent abuse)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token-here


# ─── SITE URL (client-exposed) ──────────────────────────────────────
# Used for Stripe redirect URLs, email links, and sitemap generation.
# Set to your production domain in Vercel.
# REQUIRED — used across donations, dues, and event checkout routes
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Legacy alias — some routes also check this; set it to the same value
NEXT_PUBLIC_SITE_URL=http://localhost:3000


# ─── CRON / AUTOMATION (server-only) ────────────────────────────────
# Shared secret for the dues automation endpoint (called by GitHub Actions).
# [OPTIONAL] — only needed if using dues automation cron jobs
# Also set as a GitHub Actions secret: CRON_SECRET
CRON_SECRET=your-random-secret-here


# ─── OPTIONAL SERVICES ──────────────────────────────────────────────

# Google Analytics — Vercel Analytics is the primary; GA is a no-op stub today.
# To enable: add gtag <Script> to app/layout.tsx and set this value.
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
